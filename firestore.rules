rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Legacy backups for restoration bridge
    match /backups/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Allow the user to read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Recursive match for all subcollections (transactions, categories, goals, recurring)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
