rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: check if the requesting user is an admin ───
    function isAdmin() {
      return request.auth != null 
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // Legacy backups for restoration bridge
    match /backups/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles & all subcollections
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read any user and update (for blocking)
      allow read: if isAdmin();
      allow update: if isAdmin();

      // Recursive match for subcollections (transactions, categories, goals, recurring, notifications)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }

    // Admin profiles (self-read and self-write for profile creation/updates)
    match /admins/{adminId} {
      allow read, write: if request.auth != null && request.auth.uid == adminId;
    }

    // Broadcast notifications (admin writes, all authenticated users read)
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
